add_library(SDL2::SDL2 SHARED IMPORTED)
add_library(SDL2::SDL2main STATIC IMPORTED)

set_target_properties(SDL2::SDL2 PROPERTIES INTERFACE_INCLUDE_DIRECTORIES "${CMAKE_CURRENT_LIST_DIR}/include")
set_target_properties(SDL2::SDL2main PROPERTIES INTERFACE_INCLUDE_DIRECTORIES "${CMAKE_CURRENT_LIST_DIR}/include")

if (${CMAKE_SIZEOF_VOID_P} MATCHES 8)
    set_property(TARGET SDL2::SDL2 PROPERTY IMPORTED_LOCATION "${CMAKE_CURRENT_LIST_DIR}/lib/x64/SDL2.dll")
	set_property(TARGET SDL2::SDL2 PROPERTY IMPORTED_IMPLIB "${CMAKE_CURRENT_LIST_DIR}/lib/x64/SDL2.lib")
    set_property(TARGET SDL2::SDL2main PROPERTY IMPORTED_LOCATION "${CMAKE_CURRENT_LIST_DIR}/lib/x64/SDL2main.lib")
else ()
    set_property(TARGET SDL2::SDL2 PROPERTY IMPORTED_LOCATION "${CMAKE_CURRENT_LIST_DIR}/lib/x86/SDL2.dll")
	set_property(TARGET SDL2::SDL2 PROPERTY IMPORTED_IMPLIB "${CMAKE_CURRENT_LIST_DIR}/lib/x86/SDL2.lib")
    set_property(TARGET SDL2::SDL2main PROPERTY IMPORTED_LOCATION "${CMAKE_CURRENT_LIST_DIR}/lib/x86/SDL2main.lib")
endif ()
